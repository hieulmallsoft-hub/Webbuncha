### Local development env (copy to `.env.local`)
### NOTE: `.env.local` is gitignored. Do NOT commit real secrets.

# `run-local.cmd` always runs with `--spring.profiles.active=local`,
# so you don't need SPRING_PROFILES_ACTIVE here.

### VNPay sandbox (use values from VNPay sandbox email)
VNPAY_ENABLED=true
# Fill these from your VNPay sandbox/production portal. Do not commit real secrets.
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5173/payment-result
VNPAY_IPN_URL=http://localhost:8080/payments/vnpay/ipn

### JWT (optional, fallback exists in application-local.properties)
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-bytes
