### Server / Docker example (copy to `.env` for deploy)
SPRING_PROFILES_ACTIVE=prod

### Postgres (docker-compose service name: postgres)
POSTGRES_DB=buncha_prod
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

DB_URL=jdbc:postgresql://postgres:5432/buncha_prod
DB_USERNAME=postgres
DB_PASSWORD=change-me

### Redis (docker-compose service name: redis)
CACHE_TYPE=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TIMEOUT=2s
CACHE_REDIS_TTL=10m

### Security / misc
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-bytes
CORS_ALLOWED_ORIGINS=
APP_UPLOAD_DIR=/app/uploads

### Admin seed
APP_ADMIN_ENABLED=true
APP_ADMIN_EMAIL=admin@bunchachinhhuong.vn
APP_ADMIN_PASSWORD=ChangeThisAdminPassword123!
APP_ADMIN_NAME=Bun Cha Chinh Huong Admin

### VNPay (set to true only after configuring real values)
VNPAY_ENABLED=false
# Fill these from your VNPay sandbox/production portal. Do not commit real secrets.
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=
VNPAY_IPN_URL=
