{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "mvn-package",
            "type": "shell",
            "command": "cmd.exe",
            "args": [
                "/c",
                "if exist .mvn\\wrapper\\maven-wrapper.jar (call mvnw.cmd -q -DskipTests package) else (call mvn -q -DskipTests package)"
            ],
            "options": {
                "cwd": "${workspaceFolder}\\web bun cha"
            },
            "problemMatcher": []
        },
        {
            "label": "mvn-copy-deps",
            "type": "shell",
            "command": "cmd.exe",
            "args": [
                "/c",
                "if exist .mvn\\wrapper\\maven-wrapper.jar (call mvnw.cmd -q -DskipTests dependency:copy-dependencies -DoutputDirectory=target/dependency) else (call mvn -q -DskipTests dependency:copy-dependencies -DoutputDirectory=target/dependency)"
            ],
            "options": {
                "cwd": "${workspaceFolder}\\web bun cha"
            },
            "problemMatcher": []
        },
        {
            "label": "mvn-test-compile",
            "type": "shell",
            "command": "cmd.exe",
            "args": [
                "/c",
                "if exist .mvn\\wrapper\\maven-wrapper.jar (call mvnw.cmd -q test-compile) else (call mvn -q test-compile)"
            ],
            "options": {
                "cwd": "${workspaceFolder}\\web bun cha"
            },
            "problemMatcher": []
        },
        {
            "label": "mvn-test-classpath-jar",
            "type": "shell",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "scripts\\create-test-classpath-jar.ps1"
            ],
            "options": {
                "cwd": "${workspaceFolder}\\web bun cha"
            },
            "problemMatcher": []
        },
        {
            "label": "maven-test-prepare",
            "dependsOn": [
                "mvn-test-compile",
                "mvn-copy-deps",
                "mvn-test-classpath-jar"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "maven-prepare",
            "dependsOn": [
                "mvn-package"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "spring-boot-run-local",
            "type": "shell",
            "command": "${workspaceFolder}\\run-local.cmd",
            "args": [],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ]
}
