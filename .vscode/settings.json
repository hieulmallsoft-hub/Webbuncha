{
    "java.configuration.updateBuildConfiguration": "automatic",
    "java.test.defaultConfig": "spring-rest-with-ai-tests",
    "java.test.config": [
        {
            "name": "spring-rest-with-ai-tests",
            "workingDirectory": "${workspaceFolder}/web bun cha",
            "testKind": "junit",
            "preLaunchTask": "maven-test-prepare",
            "shortenCommandLine": "argfile",
            "classPaths": [
                "${workspaceFolder}/web bun cha/target/test-classes",
                "${workspaceFolder}/web bun cha/target/classes",
                "${workspaceFolder}/web bun cha/target/test-classpath.jar"
            ],
            "vmArgs": [
                "-Dspring.profiles.active=test"
            ],
            "env": {
                "SPRING_PROFILES_ACTIVE": "test"
            }
        }
    ],
    "java.compile.nullAnalysis.mode": "automatic"
}
