{
    "configurations": [
        {
            "type": "java",
            "name": "Spring Boot-SpringRestWithAiApplication<spring-rest-with-ai>",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "vn.hoidanit.springrestwithai.SpringRestWithAiApplication",
            "projectName": "spring-rest-with-ai",
            "preLaunchTask": "maven-prepare",
            "shortenCommandLine": "argfile",
            "args": "--spring.profiles.active=local",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "type": "java",
            "name": "Attach - Spring Boot (localhost:5005)",
            "request": "attach",
            "hostName": "localhost",
            "port": 5005
        }
    ]
}
